{
  "$schema": "../../specs/erc7730-v1.schema.json",
  "includes": "../../ercs/calldata-erc7540Deposit-vaults.json",
  "context": {
    "contract": {
      "abi": [
        {
          "name": "redeem",
          "type": "function",
          "inputs": [
            { "name": "shares", "type": "uint256" },
            { "name": "receiver", "type": "address" },
            { "name": "controller", "type": "address" }
          ]
        },
        {
          "name": "withdraw",
          "type": "function",
          "inputs": [
            { "name": "assets", "type": "uint256" },
            { "name": "receiver", "type": "address" },
            { "name": "controller", "type": "address" }
          ]
        },
        {
          "name": "requestRedeem",
          "type": "function",
          "inputs": [
            { "name": "shares", "type": "uint256" },
            { "name": "controller", "type": "address" },
            { "name": "owner", "type": "address" }
          ]
        },
        {
          "name": "syncDeposit",
          "type": "function",
          "inputs": [
            { "name": "assets", "type": "uint256" },
            { "name": "receiver", "type": "address" },
            { "name": "referral", "type": "address" }
          ]
        },
        {
          "name": "syncRedeem",
          "type": "function",
          "inputs": [
            { "name": "shares", "type": "uint256" },
            { "name": "receiver", "type": "address" },
            { "name": "minimumAssets", "type": "uint256" }
          ]
        },
        {
          "name": "claimSharesAndRequestRedeem",
          "type": "function",
          "inputs": [
            { "name": "sharesToRedeem", "type": "uint256" }
          ]
        }
      ]
    }
  },
  "metadata": {
    "constants": {
      "underlyingToken": "0x0"
    }
  },
  "display": {
    "formats": {
      "redeem(uint256 shares, address receiver, address controller)": {
        "intent": "Claim redemption",
        "fields": [
          {
            "path": "shares",
            "label": "Amount of shares to finalize redemption for",
            "format": "tokenAmount",
            "params": { "tokenPath": "@.to" }
          },
          {
            "path": "receiver",
            "label": "Send assets to",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          },
          {
            "path": "controller",
            "label": "Controller of the request",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          }
        ],
        "required": ["shares", "receiver", "controller"]
      },
      "withdraw(uint256 assets, address receiver, address controller)": {
        "intent": "Withdraw",
        "fields": [
          {
            "label": "Claim withdrawal",
            "format": "raw",
            "value": "$.metadata.constants.underlyingTicker"
          },
          {
            "path": "assets",
            "label": "Amount of assets to receive",
            "format": "tokenAmount",
            "params": { "token": "$.metadata.constants.underlyingToken" }
          },
          {
            "path": "receiver",
            "label": "Send assets to",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          },
          {
            "path": "controller",
            "label": "Controller of the request",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          }
        ],
        "required": ["assets", "receiver", "controller"]
      },
      "requestRedeem(uint256 shares, address controller, address owner)": {
        "intent": "Request redemption",
        "fields": [
          {
            "path": "shares",
            "label": "Amount of shares to request redemption for",
            "format": "tokenAmount",
            "params": { "tokenPath": "@.to" }
          },
          {
            "path": "controller",
            "label": "Controller of the request",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          },
          {
            "path": "owner",
            "label": "Owner of the shares",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          }
        ],
        "required": ["shares", "controller", "owner"]
      },
      "syncDeposit(uint256 assets, address receiver, address referral)": {
        "intent": "Deposit",
        "fields": [
          {
            "path": "assets",
            "label": "Amount of assets to deposit",
            "format": "tokenAmount",
            "params": { "token": "$.metadata.constants.underlyingToken" }
          },
          {
            "label": "Receive shares",
            "format": "raw",
            "value": "$.metadata.constants.vaultTicker"
          },
          {
            "path": "receiver",
            "label": "Send shares to",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          },
          {
            "path": "referral",
            "label": "Referral",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          }
        ],
        "required": ["assets", "receiver"]
      },
      "syncRedeem(uint256 shares, address receiver, uint256 minimumAssets)": {
        "intent": "Redeem",
        "fields": [
          {
            "path": "shares",
            "label": "Amount of shares to redeem",
            "format": "tokenAmount",
            "params": { "tokenPath": "@.to" }
          },
          {
            "label": "Receive assets",
            "format": "raw",
            "value": "$.metadata.constants.underlyingTicker"
          },
          {
            "path": "receiver",
            "label": "Send assets to",
            "format": "addressName",
            "params": { "types": ["eoa", "contract"] }
          },
          {
            "path": "minimumAssets",
            "label": "Minimum assets to receive",
            "format": "tokenAmount",
            "params": { "token": "$.metadata.constants.underlyingToken" }
          }
        ],
        "required": ["shares", "receiver", "minimumAssets"]
      },
      "claimSharesAndRequestRedeem(uint256 sharesToRedeem)": {
        "intent": "Claim shares and request redemption",
        "fields": [
          {
            "path": "sharesToRedeem",
            "label": "Amount of shares to redeem",
            "format": "tokenAmount",
            "params": { "tokenPath": "@.to" }
          }
        ],
        "required": ["sharesToRedeem"]
      }
    }
  }
}
